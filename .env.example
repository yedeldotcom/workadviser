# WorkAdviser Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Base44 Backend (REQUIRED for persistence) ────────────────────────────────
# Your Base44 app ID — found in the editor URL or base44/.app.jsonc
BASE44_APP_ID=your-app-id-from-base44-dashboard

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
ADMIN_PORT=3001
NODE_ENV=development

# ─── WhatsApp Provider ────────────────────────────────────────────────────────
# Options: stub | twilio | meta
# 'stub' logs messages to console (dev/test only — no actual delivery)
WHATSAPP_PROVIDER=stub

# Meta webhook verification token — MUST be changed before production
# Set the same value in your Meta App settings → Webhooks → Verify Token
WEBHOOK_VERIFY_TOKEN=change-this-in-production

# ─── Twilio (required if WHATSAPP_PROVIDER=twilio) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Meta Cloud API (required if WHATSAPP_PROVIDER=meta) ─────────────────────
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
# App Secret for validating X-Hub-Signature-256 inbound webhook signatures
META_APP_SECRET=

# ─── Voice Transcription (optional) ──────────────────────────────────────────
# Set to 'true' to enable Whisper transcription for voice messages
VOICE_TRANSCRIPTION_ENABLED=false
# Required if VOICE_TRANSCRIPTION_ENABLED=true
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1

# ─── Anthropic Claude API (REQUIRED for interview LLM turns) ─────────────────
ANTHROPIC_API_KEY=

# ─── Display ──────────────────────────────────────────────────────────────────
# Phone number shown on the landing page
WHATSAPP_DISPLAY_NUMBER=+972-XX-XXX-XXXX
